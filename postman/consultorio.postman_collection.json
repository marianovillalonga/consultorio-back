{
  "info": {
    "_postman_id": "2c25f0a4-0e7d-4b4b-bd4a-1f2ea8bbd7b1",
    "name": "Consultorio API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"paciente@example.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Paciente Demo\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"paciente@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Activate",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/activate?token={{activationToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "activate"],
              "query": [{ "key": "token", "value": "{{activationToken}}" }]
            }
          }
        },
        {
          "name": "Resend Activation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"paciente@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/resend-activation", "host": ["{{baseUrl}}"], "path": ["auth", "resend-activation"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"paciente@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Availability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/appointments/availability?dentistId=1&date=2026-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "availability"],
              "query": [
                { "key": "dentistId", "value": "1" },
                { "key": "date", "value": "2026-01-01" }
              ]
            }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dentistId\": 1,\n  \"patientId\": 1,\n  \"startAt\": \"2026-01-01T10:00:00.000Z\",\n  \"endAt\": \"2026-01-01T10:30:00.000Z\",\n  \"reason\": \"Control\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments", "host": ["{{baseUrl}}"], "path": ["appointments"] }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/patients", "host": ["{{baseUrl}}"], "path": ["patients"] }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Paciente Demo\",\n  \"email\": \"paciente@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/patients", "host": ["{{baseUrl}}"], "path": ["patients"] }
          }
        }
      ]
    }
  ]
}
