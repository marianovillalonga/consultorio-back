{
  "openapi": "3.0.3",
  "info": {
    "title": "Consultorio API",
    "version": "1.0.0",
    "description": "API para gestion de consultorio odontologico."
  },
  "servers": [
    { "url": "http://localhost:3000/api", "description": "Local" }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Registrar paciente",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "fullName"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "fullName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Creado" } }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "identifier": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Sesion actual",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/refresh": {
      "post": {
        "summary": "Refresh token",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/activate": {
      "get": {
        "summary": "Activar cuenta",
        "parameters": [
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/resend-activation": {
      "post": {
        "summary": "Reenviar activacion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": { "email": { "type": "string", "format": "email" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "summary": "Solicitar reset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": { "email": { "type": "string", "format": "email" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/reset-password": {
      "post": {
        "summary": "Reset password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "password"],
                "properties": {
                  "token": { "type": "string" },
                  "password": { "type": "string", "minLength": 8 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/appointments/availability": {
      "get": {
        "summary": "Disponibilidad de turnos",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "parameters": [
          { "name": "dentistId", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "date", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/appointments": {
      "post": {
        "summary": "Crear turno",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "responses": { "201": { "description": "Creado" } }
      }
    },
    "/patients": {
      "get": {
        "summary": "Listar pacientes",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Crear paciente",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "responses": { "201": { "description": "Creado" } }
      }
    },
    "/patients/{id}": {
      "get": {
        "summary": "Detalle de paciente",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "patch": {
        "summary": "Actualizar paciente",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/obras-sociales": {
      "get": {
        "summary": "Listar obras sociales",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Crear obra social",
        "security": [{ "cookieAuth": [] }, { "bearerAuth": [] }],
        "responses": { "201": { "description": "Creado" } }
      }
    }
  }
}
