{
  "name": "back",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "node src/scripts/lint.js",
    "validate:env": "node src/scripts/validateEnv.js",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "seed:demo": "node src/scripts/seedDemo.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:smoke": "node --test \"tests/smoke/**/*.test.js\"",
    "test:e2e": "cross-env TEST_E2E=true TEST_STORAGE_MOCK=true node --test \"tests/e2e/**/*.test.js\"",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all"
  },
  "keywords": [],
  "author": "Mariano Villalonga",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.918.0",
    "@aws-sdk/s3-request-presigner": "^3.918.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.16.0",
    "nodemailer": "^6.9.16",
    "playwright": "^1.49.0",
    "resend": "^6.6.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2",
    "swagger-ui-express": "^5.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
